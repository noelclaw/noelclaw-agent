# noelclaw systemd user service
#
# Runs the agent as a persistent user service — auto-starts on boot,
# auto-restarts on crash, logs via journald.
#
# ── Install ───────────────────────────────────────────────────────────────────
#
#   1. Edit WorkingDirectory below to match your install path
#   2. Enable linger so the service survives logout:
#        loginctl enable-linger $USER
#   3. Install and start:
#        mkdir -p ~/.config/systemd/user
#        cp deploy/noelclaw.service ~/.config/systemd/user/noelclaw.service
#        systemctl --user daemon-reload
#        systemctl --user enable --now noelclaw
#
# ── Useful commands ───────────────────────────────────────────────────────────
#
#   systemctl --user status noelclaw          # is it running?
#   systemctl --user restart noelclaw         # restart after an update
#   journalctl --user -u noelclaw -f          # live logs
#   journalctl --user -u noelclaw --since today

[Unit]
Description=noelclaw — autonomous Base chain trading agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/YOUR_USER/noelclaw
ExecStart=/usr/bin/node agent.js start
Restart=always
RestartSec=10
StartLimitIntervalSec=120
StartLimitBurst=5
StandardOutput=journal
StandardError=journal
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=default.target
