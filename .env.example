# circuit-agent environment variables (Base chain)
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it's in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Your EVM wallet private key (hex, with or without 0x prefix)
# Generate one with: node agent.js init
# This wallet needs ETH on Base (for trades + gas) and CIRCUIT (for API calls)
PRIVATE_KEY=0x_your_evm_private_key_here

# Base chain RPC URL — public endpoint or your own node/provider
# Free options: Alchemy, Infura, QuickNode, or the public https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org

# ── LLM ───────────────────────────────────────────────────────────────────────

# MiniMax Global API key — get one at https://www.minimax.io/
# Required if using MiniMax models (default). Not needed for Ollama.
MINIMAX_API_KEY=sk-cp-...

# ── Telegram (optional but recommended) ───────────────────────────────────────

# Telegram bot token — create a bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# ── Self-hosting override (advanced) ──────────────────────────────────────────

# Only set these if you run circuit-data-api on the same server as this agent.
# CIRCUIT_API_URL overrides config/agent.json at runtime — no git changes needed.
# CIRCUIT_INTERNAL_KEY bypasses x402 CIRCUIT payment (localhost deployments only).
# Leave blank if using the public API at https://api.circuitllm.dev
CIRCUIT_API_URL=
CIRCUIT_INTERNAL_KEY=
