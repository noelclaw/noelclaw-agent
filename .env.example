# noelclaw — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it contains your private key.

# ── Required ──────────────────────────────────────────────────────────────────

# Your EVM wallet private key (0x-prefixed hex) — used for trading on Base
# Generate a new wallet: node agent.js init
PRIVATE_KEY=0x_your_private_key_here

# Base chain RPC URL — free public endpoint or your own (Alchemy/Infura/QuickNode)
BASE_RPC_URL=https://mainnet.base.org

# ── LLM ───────────────────────────────────────────────────────────────────────

# MiniMax API key — get one at https://www.minimaxi.com
MINIMAX_API_KEY=

# ── Telegram (recommended) ────────────────────────────────────────────────────

# Create a bot via @BotFather on Telegram, paste the token here
# First /start in the bot claims ownership — only you can control the agent
TELEGRAM_BOT_TOKEN=
